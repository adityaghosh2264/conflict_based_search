# Doxyfile for Conflict-Based-Search

PROJECT_NAME           = "Conflict-Based-Search"
PROJECT_NUMBER         = 1.0.0
OUTPUT_DIRECTORY       = doc
CREATE_SUBDIRS         = YES
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES

# Input files/directories
INPUT                  = cpp_files/include cpp_files/src README.md
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.cpp *.h *.md
RECURSIVE              = YES

# HTML output options
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# LaTeX output options (disabled by default to save space/time)
GENERATE_LATEX         = YES

# Configuration options related to the warning and progress messages
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# Disable Dot diagram generation if Graphviz is not installed
HAVE_DOT               = YES
